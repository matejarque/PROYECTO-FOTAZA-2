extends ../layout

block content
  .text-center.py-5
    h1.display-4 ¡Bienvenido a Fotaza 2!
    p.lead Una comunidad para compartir tus imagenes.
    hr.my-4
    
  if usuarioLogueado
    p Hola de nuevo, #{usuarioLogueado.nombre_usuario}. 
  else
    p Inicia sesión para poder subir tus fotos, comentar y votar las mejores capturas.
    
    .d-flex.justify-content-center.gap-3.mb-5
      button.btn.btn-primary.btn-lg(type="button" data-bs-toggle="modal" data-bs-target="#modalRegistro") Empezar ahora
      
      button.btn.btn-outline-secondary.btn-lg(type="button" data-bs-toggle="modal" data-bs-target="#modalIniciarSesion") Ya tengo cuenta

    
  .row.g-4 
      each pub in publicaciones 
        include ../partials/card.publicacion.pug

  nav.mt-5(aria-label="Paginación de publicaciones")
    ul.pagination.justify-content-center

      // anterior
      li.page-item.disabled
        a.page-link(href="#" tabindex="-1") ← Anterior

      li.page-item.active
        a.page-link(href="#") 1

      li.page-item
        a.page-link(href="#") 2

      li.page-item
        a.page-link(href="#") 3

      li.page-item
        a.page-link(href="#") 4

      // siguiente
      li.page-item
        a.page-link(href="#") Siguiente →