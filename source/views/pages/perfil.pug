extends ./layout

block content
  .container.mt-4

    // Perfil
    .row.mb-4
      .col-md-3
        img(src="/img/default-avatar.jpg", width="120")
      
      .col-md-9
        h3 @usuario_demo
        p Esta es la descripción del usuario.
        button.btn.btn-primary Editar perfil

    hr

    // Botones de navegación
    .row.mb-4
      .col
        button.btn.btn-outline-primary Mis publicaciones
      .col
        button.btn.btn-outline-secondary Favoritos
      .col
        button.btn.btn-outline-success Intereses

    // Publicaciones (por defecto)
    .row

      include ../partials/card.publicacion.pug
      include ../partials/card.publicacion.pug
      include ../partials/card.publicacion.pug
      include ../partials/card.publicacion.pug