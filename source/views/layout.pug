doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Fotaza 2
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css", rel="stylesheet")//- Link a Bootstrap CSS (CDN)
    link(rel="stylesheet", href="/css/style.css")
  body
    nav.navbar.navbar-expand-lg.bg-light.border-bottom
      .container-fluid.fixed-top
        
        a.navbar-brand.fw-bold(href="/") Fotaza 2
        
        //- Bototon para celulares de boostrap
        button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent")
          span.navbar-toggler-icon

        #navbarContent.collapse.navbar-collapse
          //.todos los enlaces para navegar -> tengo que agregar las rutas
          ul.navbar-nav.me-auto.mb-2.mb-lg-0
            li.nav-item
              a.nav-link(href="/explorar") Explorar

          //- Buscador
          form.d-flex.me-3(action="/buscar" method="GET" role="search")
            input.form-control.me-2(type="search" name="q" placeholder="Buscar fotos...")
            button.btn.btn-outline-primary(type="submit") Buscar

          //- usuario logueado?
          .d-flex.align-items-center
            if usuarioLogueado
              span.me-2.text-muted Hola, #{usuarioLogueado.nombre}
              a(href="/perfil")
                img.rounded-pill.border(src="/img/default-avatar.png" alt="Perfil" style="width:40px; height:40px;")
              a.btn.btn-sm.btn-outline-danger.ms-3(href="/usuarios/logout") Salir
            else
              a.btn.btn-link.text-decoration-none.me-2(href="/login") Iniciar Sesión
              a.btn.btn-primary(href="/registro") Registrate

    //- donde se va a cargar el resto de contenido
    main.container.mt-4
      block content

//para bboostrap
script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")

   