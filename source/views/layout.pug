doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Fotaza 2
    
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css", rel="stylesheet")
    link(rel="stylesheet", href="/css/style.css")
  
  body
   
    nav.navbar.navbar-expand-lg.bg-white.border-bottom.py-2.fixed-top
      .container-fluid
        a.navbar-brand.fw-bold.fs-4(href="/") Fotaza 2
        
        button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent")
          span.navbar-toggler-icon

        #navbarContent.collapse.navbar-collapse
         
          if usuarioLogueado
            form.mx-auto.w-50(action="/buscar" method="GET")
              .input-group
                span.input-group-text.bg-light.border-end-0 | 🔍
                input.form-control.bg-light.border-start-0(type="search" name="q" placeholder="Busca imágenes...")
              .d-flex.gap-2.mt-2
                select.form-select.form-select-sm(name="filtroCategoria")
                  option(value="") Todas las categorías
                  option(value="Naturaleza") Naturaleza
                  option(value="Animales") Animales
                select.form-select.form-select-sm(name="filtroOrden")
                  option(value="recientes") Mas recientes
                  option(value="valoradas") Mas valoradas
          
          ul.navbar-nav.ms-auto.align-items-center
            if usuarioLogueado
              li.nav-item
                button.btn.btn-success.runded-pill.px-3.me3(type="button" data-bs-toggle="modal" data-bs-target="#modalCrearPublicacion")
                  span.me-1| Subir

              li.nav-item.ms-2
                a.btn.btn-outline-primary.rounded-pill.px-3(href="/perfil") Perfil

              li.nav-item.ms-3.d-flex.align-items-center
                span.me-2.text-muted Hola, #{usuarioLogueado.nombre}

                a(href="/perfil")
                  img.rounded-pill.border(
                    src="/img/default-avatar.jpg"
                    alt="Perfil" style="width:35px; height:35px;")

              li.nav-item
                button.btn.btn-sm.btn-outline-danger.ms-3(
                  type="button"
                  data-bs-toggle="modal" data-bs-target="#modalCerrarLogin") Salir
            else 
               li.nav-item
                button.btn.btn-link.nav-link.fw-semibold(
                  type="button"
                  data-bs-toggle="modal" data-bs-target="#modalIniciarSesion") Iniciar sesion
              
               li.nav-item.ms-2
                button.btn.btn-outline-dark.rounded-pill.px-3(
                  type="button"
                  data-bs-toggle="modal" data-bs-target="#modalRegistro") Unirme
              
               li.nav-item.ms-2
                button.btn.btn-success.rounded-pill.px-3(
                  type="button"
                  data-bs-toggle="modal" data-bs-target="#modalCheck")
                  span.me-1 ↑
                  | Subir

          
    main.container(style="margin-top:100px")
      block content
    
    //modales
    include ./partials/modal.cerrarLogin.pug
    include ./partials/modal.registro.pug
    include ./partials/modal.iniciar-sesion.pug
    include ./partials/modal.check.pug
    include ./partials/modal.reportar.pug
    include ./partials/modal.crearPublicacion.pug
    
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    script(src="/js/validacionInicioRegistro.js")
    script(src="/js/login.js")