extends layout

block content
  .text-center.py-5
    h1.display-4 ¡Bienvenido a Fotaza 2!
    p.lead Una comunidad para compartir tus imagenes.
    hr.my-4
    
  if usuarioLogueado
    p Hola de nuevo, #{usuarioLogueado.nombre}. 
    p Aquí verás las publicaciones más valoradas o de gente que seguís.
  else
    p Inicia sesión para poder subir tus fotos, comentar y votar las mejores capturas.
    .d-flex.justify-content-center.gap-3
      button.btn.btn-primary.btn-lg(type="button" data-bs-toggle="modal" data-bs-target="#modalRegistro") Empezar ahora
      //- BOTÓN CORREGIDO:
      button.btn.btn-outline-secondary.btn-lg(type="button" data-bs-toggle="modal" data-bs-target="#modalIniciarSesion") Ya tengo cuenta

    //- El include debe llevar la misma sangría que el contenido del bloque -> estaba roto justamente por la sangría
    include ./partials/modal.registro.pug
    include ./partials/modal.iniciar-sesion.pug
    include ./partials/modal.check.pug